FROM brew.registry.redhat.io/rh-osbs/openshift-golang-builder:rhel_9_golang_1.26 AS builder

COPY ocp-secrets-management-operator/operator/bundle/manifests /manifests
COPY ocp-secrets-management-operator/operator/bundle/metadata /metadata
COPY ocp-secrets-management-operator/operator/bundle/tests/scorecard /tests/scorecard
COPY ocp-secrets-management-operator/LICENSE /licenses/


COPY images_digest.conf /images_digest.conf
COPY --chmod=0550 hack/bundle/render_templates.sh /render_templates.sh

ENV GO_BUILD_TAGS=strictfipsruntime,openssl
ENV GOEXPERIMENT=strictfipsruntime
ENV CGO_ENABLED=1
ENV GOFLAGS=""

COPY tools.go go.mod go.sum /
RUN go build -o /usr/bin/yq github.com/mikefarah/yq/v4 && chmod +x /usr/bin/yq
RUN ./render_templates.sh /manifests /metadata /images_digest.conf

FROM registry.access.redhat.com/ubi9/ubi-minimal:latest@sha256:850143255ee0d1915f09aaa09f6ed31f24086ba605c323badfbefa95b8c52b0e

ARG RELEASE_VERSION
ARG COMMIT_SHA
ARG SOURCE_URL

# Core bundle labels.
LABEL com.redhat.component="ocp-secrets-management-operator-bundle-container" \
      cpe="cpe:/a:redhat:secrets_management_operator:0.1::el9" \
      name="secrets-management-operator/ocp-secrets-management-operator-bundle" \
      summary="ocp secrets management operator for Red Hat OpenShift" \
      description="ocp secrets management operator for Red Hat OpenShift" \
      distribution-scope="public" \
      release="${RELEASE_VERSION}" \
      version="${RELEASE_VERSION}" \
      url="${SOURCE_URL}" \
      maintainer="Red Hat, Inc." \
      vendor="Red Hat, Inc." \
      com.redhat.delivery.operator.bundle=true \
      com.redhat.openshift.versions="v4.22" \
      io.openshift.expose-services="" \
      io.openshift.build.commit.id="${COMMIT_SHA}" \
      io.openshift.build.source-location="${SOURCE_URL}" \
      io.openshift.build.commit.url="${SOURCE_URL}/commit/${COMMIT_SHA}" \
      io.openshift.maintainer.product="OpenShift Container Platform" \
      io.openshift.tags="openshift,secrets,ocp-secrets-management,secrets-management-operator" \
      io.k8s.display-name="openshift-secrets-management-operator-bundle" \
      io.k8s.description="ocp-secrets-management-operator-bundle-container" \
      operators.operatorframework.io.bundle.mediatype.v1="registry+v1" \
      operators.operatorframework.io.bundle.manifests.v1=manifests/ \
      operators.operatorframework.io.bundle.metadata.v1=metadata/ \
      operators.operatorframework.io.bundle.package.v1="ocp-secrets-management-operator" \
      operators.operatorframework.io.bundle.channel.default.v1="tech-preview-v1" \
      operators.operatorframework.io.bundle.channels.v1="tech-preview-v1" \
      operators.operatorframework.io.metrics.builder="operator-sdk-v1.34.1" \
      operators.operatorframework.io.metrics.project_layout="go.kubebuilder.io/v4"

# Labels for testing.
LABEL operators.operatorframework.io.test.mediatype.v1=scorecard+v1 \
      operators.operatorframework.io.test.config.v1=tests/scorecard/

COPY --from=builder /manifests /manifests
COPY --from=builder /metadata /metadata
COPY --from=builder /tests/scorecard /tests/scorecard
COPY --from=builder /licenses /licenses

USER 65534:65534
